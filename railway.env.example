# Add these variables to API, Worker and Scheduler (prefer Railway shared variables).
DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}
JWT_SECRET=<generate-at-least-64-random-characters-and-seal-this-variable>
ALLOWED_ORIGINS=https://your-real-frontend.example.com
CRAWL_USER_AGENT=Schneider-Sales-Intelligence/1.0 contact=compliance@example.com
ENVIRONMENT=production
FORWARDED_ALLOW_IPS=*
TZ=UTC
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=14
CRAWL_TIMEOUT_SECONDS=30
CRAWL_GLOBAL_CONCURRENCY=4
CRAWL_DOMAIN_RATE_SECONDS=2
MAX_CONSECUTIVE_FAILURES=5
SEED_DEMO_DATA=false
ENABLE_INLINE_SCHEDULER=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
